<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:local="using:Eli.Avalonia.Controls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Eli.Avalonia.Controls.ParameterInputControl"
			 x:Name="MainUserControl"
			 x:DataType="local:ParameterInputControl">
	<Grid>
		<TextBlock x:Name="PlaceholderText"
				   Text="{Binding ParameterName, RelativeSource={RelativeSource AncestorType=local:ParameterInputControl}}"
				   HorizontalAlignment="Center"
				   VerticalAlignment="Center"
				   IsHitTestVisible="False"
				   />
		<local:SetValueControl x:Name="InputBox" Value="{Binding Value, RelativeSource={RelativeSource AncestorType=local:ParameterInputControl}, Mode=TwoWay}" />
	</Grid>
</UserControl>
